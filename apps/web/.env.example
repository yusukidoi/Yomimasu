# Copy to apps/web/.env.local (or .env) and fill in real values.
# Restart `pnpm dev` after changes.

# ---------------------------------------------------------
# A) Postgres URI  →  Connect → Direct  (or ORM)
#    Use Session pooler. Copy EXACT host from dashboard.
# ---------------------------------------------------------
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------
# B) Auth / API keys  →  Connect → Server
# ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# OpenAI (optional — sentence Explain falls back to demo + cache without it)
OPENAI_API_KEY=

# Vercel: add DATABASE_URL + Supabase vars in Project Settings → Environment Variables
# (Production + Preview). Build does not require DB; runtime does for reader/dashboard.
