# Copy to packages/db/.env

# IMPORTANT: Copy the exact URI from Supabase Dashboard → Connect.
# Do not guess aws-0 / region. New projects may use aws-1, aws-2, etc.
#
# Use: Session pooler (port 5432)
# Avoid: Direct connection (db.*.supabase.co) on free tier — often IPv6-only
#
# Example shape only:
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-X-YOUR-REGION.pooler.supabase.com:5432/postgres
