{
  "name": "yomimasu",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @yomimasu/db db:generate",
    "db:migrate": "pnpm --filter @yomimasu/db db:migrate",
    "db:push": "pnpm --filter @yomimasu/db db:push",
    "db:studio": "pnpm --filter @yomimasu/db db:studio",
    "db:seed": "pnpm --filter @yomimasu/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  }
}
